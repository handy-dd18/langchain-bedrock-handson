# AWS profile name configured in ~/.aws/config
# (you should be already logged in via `aws sso login --profile <name>` on the host)
AWS_PROFILE=default

# Region where Bedrock models are enabled
AWS_REGION=us-east-1

# Bedrock model IDs
# Nova Lite はクロスリージョン推論プロファイル必須です。
# AWS_REGION に応じて先頭プレフィックスが変わるので注意してください:
#   - US リージョン (us-east-1, us-west-2 等)            -> us.amazon.nova-lite-v1:0
#   - APAC リージョン (ap-northeast-1[東京], ap-southeast-1 等) -> apac.amazon.nova-lite-v1:0
#   - EU リージョン (eu-central-1 等)                     -> eu.amazon.nova-lite-v1:0
BEDROCK_CHAT_MODEL_ID=us.amazon.nova-lite-v1:0

# Titan Embeddings はプレフィックス不要(各リージョンで直接利用可能)
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# --- 05章以降で使用: LangSmith トレース ---
# https://smith.langchain.com/ で無料アカウントを作成し、API キーを発行してください。
# 詳細は docs/05_langsmith_setup.md を参照。
# LANGSMITH_API_KEY を空のままにすればトレースは無効化され、ローカル動作確認だけで進められます。
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langchain-bedrock-handson
# LangSmith のワークスペースが US 以外のリージョンにある場合は、対応する API エンドポイントを設定してください
# (キーは valid なのに 403 Forbidden が返るケースの主因はリージョン不一致です)
#   - US (デフォルト): 設定不要
#   - EU:   LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
#   - APAC: LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com

# --- 06章で使用: Bedrock Rerank モデル(任意) ---
# 一部リージョンでのみ提供されています。未提供リージョンの場合は 06 章で該当セルをスキップ可能。
BEDROCK_RERANK_MODEL_ID=amazon.rerank-v1:0
